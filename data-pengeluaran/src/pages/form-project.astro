---
// src/pages/input-project.astro
import { supabase } from '../db/supabase.js';
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Input Proyek Baru</title>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center p-6">

  <div class="bg-white p-8 rounded-xl shadow-md w-full max-w-md mx-auto">
    
    <div class="flex items-center justify-between mb-6 border-b border-gray-100 pb-4">
      <h2 class="text-xl font-bold text-gray-800">Input Proyek Baru</h2>
      <a 
        href="/" 
        class="inline-flex items-center text-xs font-bold text-blue-600 hover:text-blue-800 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-lg transition-colors"
      >
        📊 Lihat Dashboard
      </a>
    </div>

    <form id="projectForm" class="space-y-4">
      
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Nama Proyek *</label>
        <input 
          type="text" 
          id="nama_project" 
          required 
          placeholder="Contoh: GGP-MAJA atau PT XYZ" 
          class="w-full p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" 
        />
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Nilai Project / PO (Rp) *</label>
        <input 
          type="number" 
          id="nilai_project" 
          required 
          min="0" 
          placeholder="Contoh: 50000000" 
          class="w-full p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none" 
        />
      </div>

      <button 
        type="submit" 
        id="btnSubmit" 
        class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold p-3 rounded-lg transition duration-200 mt-4 shadow-sm shadow-blue-200 active:scale-98"
      >
        Simpan Proyek
      </button>
      
    </form>
  </div>

  <script>
    const form = document.getElementById('projectForm');
    const btnSubmit = document.getElementById('btnSubmit');

    form.addEventListener('submit', async (e) => {
      e.preventDefault(); // Cegah browser reload halaman
      
      btnSubmit.disabled = true;
      btnSubmit.innerText = 'Menyimpan...';

      // Kumpulkan data proyek
      const dataKirim = {
        nama_project: document.getElementById('nama_project').value,
        nilai_project: document.getElementById('nilai_project').value
      };

      try {
        const response = await fetch('/api/function-project', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(dataKirim)
        });

        const hasil = await response.json();

        if (response.ok && hasil.success) {
          alert('🔥 Sukses! Proyek baru berhasil didaftarkan ke database.');
          form.reset(); // Kosongkan form kembali setelah sukses
        } else {
          alert('❌ Gagal Menyimpan: ' + (hasil.message || 'Terjadi kesalahan sistem.'));
        }
      } catch (err) {
        alert('⚠️ Gagal Koneksi: ' + err.message);
      } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerText = 'Simpan Proyek';
      }
    });
  </script>

</body>
</html>