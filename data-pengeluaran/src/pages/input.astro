---
// src/pages/input.astro
import { supabase } from '../db/supabase.js';

// Ambil daftar proyek untuk dropdown
const { data: projects } = await supabase
  .from('project') 
  .select('project_id, nama_project')
  .order('nama_project', { ascending: true });
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Input Pengeluaran Proyek</title>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center p-6">

  <div class="bg-white p-8 rounded-xl shadow-md w-full max-w-md mx-auto">
    <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">Input Pengeluaran</h2>

    <form id="expenseForm" class="space-y-4">
      
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Pilih Proyek *</label>
        <select id="project_id" required class="w-full p-2.5 border border-gray-300 rounded-lg bg-white">
          <option value="">-- Pilih Proyek --</option>
          {projects?.map((project) => (
            <option value={project.project_id}>{project.nama_project}</option>
          ))}
        </select>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Kategori Pengeluaran *</label>
        <select id="kategori" required class="w-full p-2.5 border border-gray-300 rounded-lg bg-white">
          <option value=""> -- Pilih Kategori --</option>
          <option value="material">📦 Material / Logistik</option>
          <option value="jasa">🛠️ Jasa / Tukang / Subkon</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Tanggal *</label>
        <input type="date" id="date" required class="w-full p-2.5 border border-gray-300 rounded-lg" />
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">PIC (Nama)</label>
        <input type="text" id="pic" placeholder="Contoh: ujang" class="w-full p-2.5 border border-gray-300 rounded-lg" />
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Keterangan</label>
        <textarea id="keterangan" placeholder="Contoh: beli material atau ongkos tukang" rows="3" class="w-full p-2.5 border border-gray-300 rounded-lg"></textarea>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Jumlah Uang / Kredit (Rp) *</label>
        <input type="number" id="kredit" required min="0" placeholder="Contoh: 1500000" class="w-full p-2.5 border border-gray-300 rounded-lg" />
      </div>

      <button type="submit" id="btnSubmit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold p-3 rounded-lg transition duration-200 mt-4">
        Simpan Pengeluaran
      </button>
      
    </form>
  </div>

  <script>
    // Otomatis bersihkan URL dari sisa parameter error lawas jika ada
    if (window.location.search) {
      window.history.replaceState({}, document.title, window.location.pathname);
    }

    const form = document.getElementById('expenseForm');
    const btnSubmit = document.getElementById('btnSubmit');

    form.addEventListener('submit', async (e) => {
      e.preventDefault(); // Cegah browser reload halaman
      
      btnSubmit.disabled = true;
      btnSubmit.innerText = 'Menyimpan...';

      // Kumpulkan data termasuk nilai dropdown KATEGORI yang baru
      const dataKirim = {
        project_id: document.getElementById('project_id').value,
        kategori: document.getElementById('kategori').value, // <-- IKUT DIKIRIM
        date: document.getElementById('date').value,
        pic: document.getElementById('pic').value,
        keterangan: document.getElementById('keterangan').value,
        kredit: document.getElementById('kredit').value
      };

      try {
        const response = await fetch('/api/function', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(dataKirim)
        });

        const hasil = await response.json();

        if (response.ok && hasil.success) {
          alert('🔥 Sukses! Data pengeluaran berhasil disimpan ke database.');
          form.reset(); // Kosongkan isi form kembali setelah sukses
        } else {
          alert('❌ Gagal Menyimpan: ' + (hasil.message || 'Terjadi kesalahan sistem.'));
        }
      } catch (err) {
        alert('⚠️ Gagal Koneksi: ' + err.message);
      } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerText = 'Simpan Pengeluaran';
      }
    });
  </script>

<button><a href="/">Dashboard</a></button>
</body>
</html>