---
// src/pages/input.astro
import { supabase } from '../db/supabase.js';

let statusMessage = '';
let statusType = ''; // 'success' atau 'error'

// 1. Ambil daftar proyek untuk dropdown pilihan di Form
const { data: projects, error: projectError } = await supabase
  .from('project')
  .select('project_id, nama_project, nilai_project')
  .order('nama_project', { ascending: true });

// 2. Logika ketika Form di-SUBMIT (POST Request)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const projectId = formData.get('project_id');
    const date = formData.get('date');
    const pic = formData.get('pic');
    const description = formData.get('description');
    const amount = formData.get('kredit');

    // Validasi sederhana masukan data
    if (!projectId || !date || !amount) {
      throw new Error('Proyek, Tanggal, dan Jumlah wajib diisi!');
    }

    // 3. Masukkan (Insert) data ke tabel 'pengeluaran' di Supabase
