---

<html lang="id">
<head>  
  <meta charset="UTF-8" />
  <title>Input Pengeluaran Proyek</title>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center p-6">

  <div class="bg-white p-8 rounded-xl shadow-md w-full max-w-md">
    <h2 class="text-2xl font-bold text-gray-800 mb-6 text-center">Input Pengeluaran</h2>

    {statusMessage && (
      <div class={`p-4 mb-4 rounded-lg text-sm font-medium ${statusType === 'success' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
        {statusMessage}
      </div>
    )}

    <form method="POST" class="space-y-4">
      
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Pilih Proyek *</label>
        <select name="project_id" required class="w-full p-2.5 border border-gray-300 rounded-lg">
        <option value="">-- Pilih Proyek --</option>
        {projects?.map((project) => (
          // Ganti project.id dan project.name sesuai nama kolom di Supabase Anda
          <option value={projects.project_id}>{projects.nama_project || projects.nama_project}</option>
        ))}
      </select>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Tanggal *</label>
        <input type="date" name="date" required class="w-full p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">PIC (Nama)</label>
        <input type="text" name="pic" placeholder="Contoh: ujang, liana" class="w-full p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Keterangan / Keperluan</label>
        <textarea name="description" placeholder="Contoh: beli material, ops mobil" rows="3" class="w-full p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"></textarea>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">Jumlah Uang (Rp) *</label>
        <input type="number" name="amount" required min="0" placeholder="Contoh: 1500000" class="w-full p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
      </div>

      <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold p-3 rounded-lg transition duration-200 mt-4">
        Simpan Pengeluaran
      </button>
      
    </form>
  </div>

</body>
</html>