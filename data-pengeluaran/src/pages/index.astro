  <script>
  (window as any).hapusTransaksi = async (id: number) => {
    if (!confirm('Apakah Anda yakin ingin menghapus data transaksi pengeluaran ini secara permanen dari dashboard?')) return;

    try {
      const response = await fetch('/api/function', {
        method: 'DELETE',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ id: id })
      });

      const hasil = await response.json();

      if (response.ok && hasil.success) {
        alert('🗑️ Sukses! Data transaksi berhasil dihapus.');
        window.location.reload();
      } else {
        alert('❌ Gagal Menghapus: ' + (hasil.message || 'Terjadi kesalahan internal.'));
      }
    } catch (err: any) {
      alert('⚠️ Gagal Hubungan Koneksi: ' + err.message);
    }
  };

(window as any).filterKategori = (kategori: string) => {
    const rows = document.querySelectorAll('.expense-row');
    rows.forEach((row: Element) => {
      const htmlRow = row as HTMLElement;
      if (kategori === 'semua' || htmlRow.dataset.kategori === kategori) {
        htmlRow.style.display = '';
      } else {
        htmlRow.style.display = 'none';
      }
    });

    // Update style tombol aktif
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.classList.remove('bg-slate-800', 'text-white', 'bg-amber-500', 'bg-purple-500');
      btn.classList.add('opacity-60');
    });

    const activeBtn = document.getElementById(`btn-${kategori}`);
    if (activeBtn) {
      activeBtn.classList.remove('opacity-60');
      if (kategori === 'semua') activeBtn.classList.add('bg-slate-800', 'text-white');
      if (kategori === 'material') activeBtn.classList.add('bg-amber-500', 'text-white');
      if (kategori === 'jasa') activeBtn.classList.add('bg-purple-500', 'text-white');
    }
  };
  (window as any).exportCSV = () => {
    const rows = document.querySelectorAll('.expense-row');
    const visibleRows: string[][] = [];

    // Header kolom
    visibleRows.push(['Tanggal', 'Kategori', 'PIC', 'Keterangan', 'Nominal (Kredit)']);

    rows.forEach((row: Element) => {
      const htmlRow = row as HTMLElement;
      if (htmlRow.style.display === 'none') return; // Skip yang disembunyikan filter

      const cells = htmlRow.querySelectorAll('td');
      const tanggal = cells[0]?.textContent?.trim() || '';
      const kategori = cells[1]?.textContent?.trim() || '';
      const pic = cells[2]?.textContent?.trim() || '';
      const keterangan = cells[3]?.textContent?.trim() || '';
      const nominal = cells[4]?.textContent?.trim() || '';

      visibleRows.push([tanggal, kategori, pic, keterangan, nominal]);
    });

    // Konversi ke format CSV
    const csvContent = visibleRows
      .map(row => row.map(cell => `"${cell.replace(/"/g, '""')}"`).join(','))
      .join('\n');

    // Download file
    const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `transaksi-${new Date().toISOString().slice(0, 10)}.csv`;
    link.click();
    URL.revokeObjectURL(url);
  };
    
  </script>


(window as any).hitungUlangMargin = (tanpaJasa) => {
  const nilaiProject = Number(nilaiProjectVar);
  const totalMaterialJS = Number(totalMaterialVar);
  const totalJasaJS = Number(totalJasaVar);

  const costAktif = tanpaJasa ? totalMaterialJS : totalMaterialJS + totalJasaJS;
  const profitAktif = nilaiProject - costAktif;
  const marginAktif = nilaiProject > 0 ? (profitAktif / nilaiProject) * 100 : 0;

  const formatRp = (angka) =>
    new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(angka);

  const elCost = document.getElementById('display-total-cost');
  const elProfit = document.getElementById('display-profit');
  const elMargin = document.getElementById('display-margin');
  const barCost = document.getElementById('bar-cost');
  const barProfit = document.getElementById('bar-profit');

  if (elCost) elCost.textContent = formatRp(costAktif);
  if (elProfit) elProfit.textContent = formatRp(profitAktif);
  if (elMargin) elMargin.textContent = marginAktif.toFixed(1);

  if (barCost) barCost.style.width = `${Math.min((costAktif / (nilaiProject || 1)) * 100, 100).toFixed(1)}%`;
  if (barProfit) barProfit.style.width = `${Math.min(Math.abs(profitAktif / (nilaiProject || 1)) * 100, 100).toFixed(1)}%`;
};

